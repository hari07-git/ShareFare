# ============================================================
# ShareFare — Full-Stack Monorepo .gitignore
# ============================================================

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editors ───────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
nbproject/
*.swp
*.swo
*~

# ─── Environment & Secrets ───────────────────────────────────
# NEVER commit real credentials
.env
.env.local
.env.*
.env.development.local
.env.test.local
.env.production.local
*.env
!*.env.example

# ─── Frontend (React / Vite) ─────────────────────────────────
sharefare-frontend/node_modules/
sharefare-frontend/dist/
sharefare-frontend/build/
sharefare-frontend/.cache/
sharefare-frontend/.parcel-cache/
sharefare-frontend/coverage/
sharefare-frontend/.eslintcache
sharefare-frontend/storybook-static/
sharefare-frontend/playwright-report/
sharefare-frontend/test-results/
sharefare-frontend/lighthouse-report/
sharefare-frontend/.lighthouseci/

# ─── Backend (Spring Boot / Maven) ───────────────────────────
sharefare-backend/target/
sharefare-backend/.mvn/wrapper/maven-wrapper.jar

# Database files (H2 local dev DB — never commit)
sharefare-backend/data/*.mv.db
sharefare-backend/data/*.trace.db
sharefare-backend/data/*.lock.db
sharefare-backend/data/

# Logs
sharefare-backend/startup.log
sharefare-backend/logs/
sharefare-backend/*.log
*.log

# Uploaded student ID files — private by law
sharefare-backend/uploads/

# Spring Boot local config overrides
sharefare-backend/src/main/resources/application-local.properties
sharefare-backend/src/main/resources/application-local.yml
sharefare-backend/src/main/resources/application-secrets.yml

# Maven local repo cache (if nested)
.m2/

# ─── Mobile (React Native / Expo) ────────────────────────────
sharefare-mobile/node_modules/
sharefare-mobile/.expo/
sharefare-mobile/dist/
sharefare-mobile/build/
sharefare-mobile/android/
sharefare-mobile/ios/
sharefare-mobile/.cache/

# ─── Docker ──────────────────────────────────────────────────
# Keep docker-compose.yml but ignore overrides with secrets
docker-compose.override.yml
docker-compose.local.yml

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
run-local.sh
start-sharefare.sh

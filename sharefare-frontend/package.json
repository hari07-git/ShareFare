{
  "name": "sharefare-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:mobile": "playwright test e2e/mobile.spec.ts --project=\"iPhone 14\" --project=\"iPhone SE\" --project=\"Pixel 7\" --project=\"Samsung Galaxy\"",
    "test:visual": "playwright test e2e/visual.spec.ts --project=chromium",
    "test:e2e:report": "playwright show-report",
    "lighthouse": "npm run build && start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4173\" http://127.0.0.1:4173 \"node scripts/lighthouse-audit.mjs\"",
    "test:all": "npm run build && npm run test:e2e && npm run test:mobile && npm run lighthouse"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "lighthouse": "^12.8.2",
    "postcss": "^8.4.47",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.8",
    "wait-on": "^8.0.5"
  }
}

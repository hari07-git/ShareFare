# ============================================================
# ShareFare — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=8080

# ─── Database ────────────────────────────────────────────────
# Local H2 (default — no setup needed for development)
DB_URL=jdbc:h2:file:./data/sharefare-local;MODE=PostgreSQL;DB_CLOSE_ON_EXIT=FALSE
DB_USER=sa
DB_PASSWORD=

# PostgreSQL (production — uncomment and fill in):
# DB_URL=jdbc:postgresql://localhost:5432/sharefare
# DB_USER=sharefare_user
# DB_PASSWORD=your_strong_password_here

# ─── JWT Authentication ───────────────────────────────────────
# Must be at least 32 characters long — use a random secret
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_TTL_SECONDS=86400

# ─── Admin Account ───────────────────────────────────────────
# Initial admin credentials — change immediately after first login
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisPassword@123

# ─── Sample / Seed Data ──────────────────────────────────────
SAMPLE_DATA_ENABLED=true
SAMPLE_DATA_RIDES=8

# ─── Email / Brevo Transactional API ─────────────────────────
# Create an API key in Brevo → SMTP & API → API keys.
# Sender must be a verified Brevo sender.
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER=ShareFare <no-reply@yourdomain.com>
MAIL_SUPPORT_EMAIL=support@yourdomain.com

# ─── Reminders ───────────────────────────────────────────────
REMINDERS_ENABLED=true
REMINDERS_FIXED_DELAY_MS=900000

# ─── Frontend ────────────────────────────────────────────────
# Backend API URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# Used by backend for redirect links in emails
FRONTEND_BASE_URL=http://localhost:5173
